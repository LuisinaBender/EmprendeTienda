@page "/ventas"
@using Service.Models
@inject IGenericService<Venta> VentaService
@inject NavigationManager NavigationManager



<h3>Ventas</h3>

<button class="btn btn-success mb-3" @onclick="AgregarVenta">Agregar Venta</button>

@if (ventas == null)
{
    <p><em>Obteniendo lista de Ventas...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Fecha</th>
                <th>ClienteId</th>
                <th>Cliente</th>
                <th>Localidad</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var venta in ventas)
            {
                <tr>
                    <td>@venta.Id</td>
                    <td>@venta.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@venta.ClienteId</td>
                    <td>@venta.Cliente?.Nombre</td>
                    <td>@venta.Cliente?.Localidad?.Nombre</td>
                    <td>
                        <button class="btn btn-primary btn-sm" @onclick="() => VerDetalleVenta(venta.Id)">Ver detalle de venta</button>
                    </td>

                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Venta>? ventas;

    protected override async Task OnInitializedAsync()
    {
        ventas = await VentaService.GetAllAsync();
    }

    private void AgregarVenta()
    {
        NavigationManager.NavigateTo("/agregarventa");
    }

    private void VerDetalleVenta(int ventaId)
    {
        NavigationManager.NavigateTo($"/detalleventas/{ventaId}");
    }

}
