@page "/agregarventa"
@using Service.Models
@inject IGenericService<Venta> VentaService
@inject IGenericService<Cliente> ClienteService
@inject NavigationManager NavigationManager

<h3>Agregar Venta</h3>

@if (clientes == null)
{
    <p><em>Cargando clientes...</em></p>
}
else
{
    <EditForm Model="nuevaVenta" OnValidSubmit="GuardarVenta">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="fecha" class="form-label">Fecha</label>
            <InputDate id="fecha" class="form-control" @bind-Value="nuevaVenta.Fecha" />
        </div>

        <div class="mb-3">
            <label for="cliente" class="form-label">Cliente</label>
            <InputSelect id="cliente" class="form-select" @bind-Value="nuevaVenta.ClienteId">
                <option value="">-- Selecciona un cliente --</option>
                @foreach (var cliente in clientes)
                {
                    <option value="@cliente.Id">@cliente.Nombre</option>
                }
            </InputSelect>
        </div>

        <button type="submit" class="btn btn-success">Guardar Venta</button>
        <button type="button" class="btn btn-secondary ms-2" @onclick="Volver">Cancelar</button>
    </EditForm>
}

@code {
    private Venta nuevaVenta = new() { Fecha = DateTime.Now };
    private List<Cliente>? clientes;

    protected override async Task OnInitializedAsync()
    {
        clientes = await ClienteService.GetAllAsync();
    }

    private async Task GuardarVenta()
    {
        // await VentaService.CreateAsync(nuevaVenta);
        // NavigationManager.NavigateTo("/ventas");
    }

    private void Volver()
    {
        NavigationManager.NavigateTo("/ventas");
    }
}
